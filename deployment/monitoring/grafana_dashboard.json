{
  "dashboard": {
    "title": "ADE-FCM Cluster & Algorithm Monitoring",
    "version": 1,
    "editable": true,
    "gnetId": null,
    "graphTooltip": 0,
    "panels": [
      {
        "title": "Cluster Quality Metrics",
        "type": "stat",
        "id": 1,
        "gridPos": { "h": 8, "w": 4, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "avg(ade_fcm_silhouette_score)",
            "legendFormat": "Silhouette Score",
            "refId": "A"
          },
          {
            "expr": "avg(ade_fcm_davies_bouldin_index)",
            "legendFormat": "Davies-Bouldin Index",
            "refId": "B"
          },
          {
            "expr": "avg(ade_fcm_calinski_harabasz_score)",
            "legendFormat": "Calinski-Harabasz Score",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "mappings": [],
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 0.3 },
                { "color": "green", "value": 0.7 }
              ]
            },
            "unit": "none"
          }
        }
      },
      {
        "title": "Silhouette Score Over Time",
        "type": "timeseries",
        "id": 2,
        "gridPos": { "h": 8, "w": 8, "x": 4, "y": 0 },
        "targets": [
          {
            "expr": "ade_fcm_silhouette_score{dataset=~\"$dataset\"}",
            "legendFormat": "{{dataset}} k={{n_clusters}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "min": -1,
            "max": 1
          }
        }
      },
      {
        "title": "Convergence Plot",
        "type": "timeseries",
        "id": 3,
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "ade_fcm_objective_function{dataset=~\"$dataset\"}",
            "legendFormat": "{{dataset}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "custom": {
              "lineInterpolation": "stepBefore"
            }
          }
        }
      },
      {
        "title": "Number of Clusters",
        "type": "gauge",
        "id": 4,
        "gridPos": { "h": 8, "w": 4, "x": 18, "y": 0 },
        "targets": [
          {
            "expr": "ade_fcm_n_clusters",
            "legendFormat": "Clusters",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 2,
            "max": 100,
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 20 },
                { "color": "red", "value": 50 }
              ]
            }
          }
        }
      },
      {
        "title": "CPU Utilization",
        "type": "timeseries",
        "id": 5,
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "avg by(instance) (rate(process_cpu_seconds_total[1m])) * 100",
            "legendFormat": "{{instance}}",
            "refId": "A"
          },
          {
            "expr": "avg(rate(process_cpu_seconds_total[1m])) * 100",
            "legendFormat": "Average",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        }
      },
      {
        "title": "Memory Utilization (GB)",
        "type": "timeseries",
        "id": 6,
        "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
        "targets": [
          {
            "expr": "process_resident_memory_bytes / 1e9",
            "legendFormat": "{{instance}} RSS",
            "refId": "A"
          },
          {
            "expr": "avg(process_resident_memory_bytes / 1e9)",
            "legendFormat": "Average RSS",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "gb",
            "min": 0
          }
        }
      },
      {
        "title": "Spark Executors",
        "type": "stat",
        "id": 7,
        "gridPos": { "h": 4, "w": 3, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "count(spark_executor_cores) or vector(0)",
            "legendFormat": "Active Executors",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "green", "value": 3 }
              ]
            }
          }
        }
      },
      {
        "title": "Executor Cores",
        "type": "stat",
        "id": 8,
        "gridPos": { "h": 4, "w": 3, "x": 15, "y": 8 },
        "targets": [
          {
            "expr": "sum(spark_executor_cores) or vector(0)",
            "legendFormat": "Total Cores",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 4 },
                { "color": "green", "value": 12 }
              ]
            }
          }
        }
      },
      {
        "title": "Spark Task Progress",
        "type": "bargauge",
        "id": 9,
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
        "targets": [
          {
            "expr": "spark_stage_duration_sum{quantile=\"0.5\"}",
            "legendFormat": "P50 Duration",
            "refId": "A"
          },
          {
            "expr": "spark_stage_duration_sum{quantile=\"0.95\"}",
            "legendFormat": "P95 Duration",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "min": 0
          }
        }
      },
      {
        "title": "Algorithm Performance Metrics",
        "type": "table",
        "id": 10,
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "ade_fcm_runtime_seconds{dataset=~\"$dataset\"}",
            "legendFormat": "",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          { "id": "organize", "options": { "excludeByName": {}, "indexByName": {} } }
        ]
      },
      {
        "title": "Runtime by Dataset",
        "type": "barchart",
        "id": 11,
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
        "targets": [
          {
            "expr": "ade_fcm_runtime_seconds{dataset=~\"$dataset\"}",
            "legendFormat": "{{dataset}} k={{n_clusters}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "min": 0
          }
        }
      },
      {
        "title": "Streaming Throughput",
        "type": "timeseries",
        "id": 12,
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
        "targets": [
          {
            "expr": "rate(ade_fcm_records_processed_total[1m])",
            "legendFormat": "Records/sec",
            "refId": "A"
          },
          {
            "expr": "ade_fcm_streaming_lag_seconds",
            "legendFormat": "Lag (s)",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "cps",
            "min": 0
          }
        }
      },
      {
        "title": "Cluster Centroids Drift",
        "type": "heatmap",
        "id": 13,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
        "targets": [
          {
            "expr": "ade_fcm_centroid_drift",
            "legendFormat": "Drift",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "min": 0
          }
        }
      },
      {
        "title": "Membership Matrix Entropy",
        "type": "timeseries",
        "id": 14,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
        "targets": [
          {
            "expr": "ade_fcm_membership_entropy",
            "legendFormat": "Entropy",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "min": 0
          }
        }
      }
    ],
    "rows": [],
    "schemaVersion": 36,
    "style": "dark",
    "tags": ["ade-fcm", "clustering", "spark", "research"],
    "templating": {
      "list": [
        {
          "name": "dataset",
          "type": "query",
          "query": "label_values(ade_fcm_silhouette_score, dataset)",
          "refresh": 1,
          "includeAll": true,
          "multi": true,
          "allValue": ".*"
        },
        {
          "name": "n_clusters",
          "type": "query",
          "query": "label_values(ade_fcm_silhouette_score, n_clusters)",
          "refresh": 1,
          "includeAll": true,
          "multi": true
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Training Start",
          "type": "events",
          "datasource": "Prometheus",
          "expr": "ade_fcm_training_started",
          "iconColor": "green",
          "enable": true
        },
        {
          "name": "Training End",
          "type": "events",
          "datasource": "Prometheus",
          "expr": "ade_fcm_training_completed",
          "iconColor": "red",
          "enable": true
        },
        {
          "name": "Model Registered",
          "type": "events",
          "datasource": "Prometheus",
          "expr": "ade_fcm_model_registered",
          "iconColor": "blue",
          "enable": true
        }
      ]
    },
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"],
      "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
    },
    "timezone": "browser"
  },
  "overwrite": true
}
